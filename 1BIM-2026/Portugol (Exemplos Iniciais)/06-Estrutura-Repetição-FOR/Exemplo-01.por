programa {
    funcao inicio() {
        
        // Declara uma variável inteira chamada i (contador)
        inteiro i
        
        // Estrutura de repetição "para"
        // i começa em 1
        // o laço continua enquanto i for menor ou igual a 10
        // a cada repetição, i aumenta +1
        para (i = 1; i <= 10; i++) {
            
            // Exibe a mensagem na tela
            // \n serve para pular uma linha
            escreva("Olá, mundo!\n")
        }
        
    }
}