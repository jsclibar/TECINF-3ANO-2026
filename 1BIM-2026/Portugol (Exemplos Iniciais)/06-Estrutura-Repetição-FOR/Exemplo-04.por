programa {
    funcao inicio() {
        
        // Declara a variável contador
        inteiro i
        
        // Laço que conta de 1 até 10
        para (i = 1; i <= 10; i++) {
            
            // Mostra o número atual multiplicado por 2
            // Ou seja, não estamos só contando...
            // estamos FAZENDO algo com o valor
            escreva("O dobro de ", i, " é ", i * 2, "\n")
        }
        
    }
}
