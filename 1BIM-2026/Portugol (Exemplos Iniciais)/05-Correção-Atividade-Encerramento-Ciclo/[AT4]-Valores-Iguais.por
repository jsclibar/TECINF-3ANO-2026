programa
{
    funcao inicio()
    {
        inteiro a, b, c

        leia(a)
        leia(b)
        leia(c)

        se (a == b e b == c)
        {
            escreva("Os três valores são iguais.")
        }
        senao se (a == b ou a == c ou b == c)
        {
            escreva("Dois valores são iguais.")
        }
        senao
        {
            escreva("Todos os valores são diferentes.")
        }
    }
}